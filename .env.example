# RADAR Environment Variables
# Copy to .env and fill in all values before running

# ── SumoPod AI API ────────────────────────────────────────────────────────────
SUMOPOD_API_KEY=
SUMOPOD_API_BASE=https://api.sumopod.com/v1

# Models
MODEL_PRIMARY=kimi-k2.6
MODEL_FAST=                 # Optional — leave empty to use MODEL_PRIMARY for all agents

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_CHAT_ID=          # Your personal chat ID for DM delivery
TELEGRAM_MONITOR_CHAT_IDS=      # Comma-separated group IDs to monitor

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_MONITOR_CHANNEL_IDS=    # Comma-separated channel IDs to monitor

# ── Email (Resend.com — free 3,000/month, no Google Console) ─────────────────
RESEND_API_KEY=                 # Get from resend.com → API Keys
RESEND_FROM=APPA <onboarding@resend.dev>  # Use resend.dev domain (free) or your own domain

# ── Storage (SQLite — no setup needed) ───────────────────────────────────────
SQLITE_DB_PATH=/app/working/workspaces/default/radar.db

# ── RADAR Config ──────────────────────────────────────────────────────────────
MAX_OPPORTUNITIES_PER_DAY=20    # Cost guard — max pipeline runs per day
AGENT_TIMEOUT_SECONDS=30        # Per-agent timeout before graceful skip
AMBIGUOUS_SCORE_MIN=4           # Score range that triggers clarification loop
AMBIGUOUS_SCORE_MAX=6
MORNING_DIGEST_CRON=0 0 * * *   # 00:00 UTC = 07:00 WIB
